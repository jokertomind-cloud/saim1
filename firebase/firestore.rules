rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasAdminClaim() {
      return signedIn() &&
        request.auth.token.keys().hasAny(["admin"]) &&
        request.auth.token.admin == true;
    }

    function hasAdminRoleDocument() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return hasAdminClaim() || hasAdminRoleDocument();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == "user";
      allow update: if isAdmin() || (
        isOwner(uid) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "displayName",
          "gender",
          "avatarId",
          "updatedAt",
          "lastLoginAt"
        ])
      );
    }

    match /userProgress/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /userVideoStats/{docId} {
      allow read: if signedIn() && ((resource != null && resource.data.uid == request.auth.uid) || isAdmin());
      allow create, update: if signedIn() && (request.resource.data.uid == request.auth.uid || isAdmin());
    }

    match /userQuizResults/{docId} {
      allow read: if signedIn() && ((resource != null && resource.data.uid == request.auth.uid) || isAdmin());
      allow create, update: if signedIn() && (request.resource.data.uid == request.auth.uid || isAdmin());
    }

    match /avatars/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /maps/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mapPoints/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quizzes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quizQuestions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
